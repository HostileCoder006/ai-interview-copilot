# ─── OpenRouter API keys ───────────────────────────────────────────────────────
# Get keys at https://openrouter.ai/keys
# Both Whisper and DeepSeek run through OpenRouter — you can use one key for all,
# or split transcription vs evaluation:

OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional separate keys:
# OPENROUTER_TRANSCRIPTION_API_KEY=your_whisper_key_here
# OPENROUTER_EVALUATION_API_KEY=your_deepseek_key_here

# ─── Optional model overrides ─────────────────────────────────────────────────
# OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-large-v3
# OPENROUTER_EVALUATION_MODEL=deepseek/deepseek-v4-flash
